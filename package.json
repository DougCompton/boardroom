{
  "name": "@justyn-clark/boardroom",
  "version": "0.1.0",
  "description": "Boardroom is a Pi-based executive deliberation pack from Justin Clark Network.",
  "license": "Apache-2.0",
  "author": "Justin Clark Network",
  "homepage": "https://github.com/justyn-clark/boardroom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justyn-clark/boardroom.git"
  },
  "bugs": {
    "url": "https://github.com/justyn-clark/boardroom/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "boardroom",
    "executive-deliberation",
    "multi-agent",
    "justin-clark-network",
    "jcn"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    ".pi",
    ".small",
    "AGENTS.md",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "bin": {
    "boardroom": "dist/src/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "pi -e apps/ceo/extensions/ceo-and-board.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/src/cli.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/boardroom/*.test.js",
    "package:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm test && npm run package:check"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@mariozechner/pi-tui": "^0.62.0",
    "@sinclair/typebox": "^0.34.48",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  }
}
